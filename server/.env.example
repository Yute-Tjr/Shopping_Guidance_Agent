# ============================================
# 后端环境变量模板
# 使用方式：cp .env.example .env  然后填入真实值
# 严禁把含密钥的 .env 提交到 Git
# ============================================

# ---- LLM (火山方舟) ----
# 主办方分配的 key，用于调 LLM 端点
ARK_API_KEY=ark-your-llm-key-here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=ep-your-llm-endpoint-id-here

# ---- Embedding ----
# 若 Embedding 端点与 LLM 不在同一个方舟账号下，单独填这里；
# 否则可留空，代码会自动回退到 ARK_API_KEY。
ARK_EMBEDDING_API_KEY=
EMBEDDING_MODEL=ep-your-embedding-endpoint-id-here
VISION_EMBEDDING_MODEL=ep-your-vision-endpoint-id-here
EMBEDDING_DIM=2048

# ----语音合成----
ARK_AUDIO_API_KEY=
ARK_ASR_MODEL=
ARK_TTS_MODEL=
ARK_TTS_DEFAULT_VOICE=
ARK_ASR_RESOURCE_ID=
ARK_TTS_RESOURCE_ID=

# ---- Storage ----
# Milvus Lite 嵌入式数据库文件路径（相对 server/ 目录）
MILVUS_DB_PATH=./data/milvus_lite.db

# MySQL 8.0：必须 charset=utf8mb4；驱动用 asyncmy
# 格式： mysql+asyncmy://<user>:<password>@<host>:<port>/<dbname>?charset=utf8mb4
MYSQL_DSN=mysql+asyncmy://shopping_user:shopping_pwd@127.0.0.1:3306/shopping_guide?charset=utf8mb4
MYSQL_POOL_SIZE=10
MYSQL_POOL_RECYCLE=1800

# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=*

# 商品图静态资源公网地址。部署到 Nginx 后填 http://<公网IP> 或 https://<域名>；
# 留空时后端会回退到 http://127.0.0.1:<PORT>，只适合本机开发。
STATIC_BASE_URL=

# ---- Optional ----
# 留空则用进程内字典做兜底，不强依赖 Redis
REDIS_URL=
